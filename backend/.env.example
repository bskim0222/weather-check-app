PORT=8796

# mock: keep provider snapshots fully local
# yr: replace only the Yr.no provider values with live Locationforecast data
# kma: replace only the KMA provider values with live KMA short forecast data
# fmi: replace the third provider values with live FMI Open Data / ECMWF forecast data
# windy: replace only the Windy provider values with live Point Forecast data
# kma,yr,fmi: recommended MVP live comparison mode
# kma,yr,windy: optional live mode when a Windy key is available
WEATHER_PROVIDER_MODE=mock

# Required when WEATHER_PROVIDER_MODE=yr.
# Yr/MET requires a clear User-Agent with contact information.
# Example: WeatherCheck/0.1 weathercheck.official@gmail.com
YR_USER_AGENT=

# Required when WEATHER_PROVIDER_MODE includes kma.
# Keep the real key in your local environment only.
KMA_SERVICE_KEY=

# WEATHER_PROVIDER_MODE=fmi does not require an API key.
# FMI Open Data uses CC BY 4.0 attribution terms.

# Required when WEATHER_PROVIDER_MODE includes windy.
# This must be a Windy Point Forecast API key.
WINDY_API_KEY=
WINDY_MODEL=gfs
