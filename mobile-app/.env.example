# mock: use bundled sample data
# api: call the local/hosted backend first, then fall back to sample data
EXPO_PUBLIC_DATA_MODE=api

# Local backend example:
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8796
EXPO_PUBLIC_API_BASE_URL=https://weather-check-backend-hvfs.onrender.com

# Provider keys should stay on the backend.
# Keep app-side provider values empty unless a future provider explicitly requires client-side access.
EXPO_PUBLIC_KMA_API_KEY=
EXPO_PUBLIC_WINDY_API_KEY=
EXPO_PUBLIC_YR_USER_AGENT=
